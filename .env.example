# Simi Avatar — environment variable template
# Copy to .env.local (local) or configure via wrangler vars/secret (deploy).
# WARNING: never put any real API key / secret in this file or in the repo.

# --- Required (public vars) ---
NEXT_PUBLIC_APP_NAME=Simi Avatar
NEXT_PUBLIC_GITHUB_URL=https://github.com/simi-studio/avatar
NEXT_PUBLIC_DEFAULT_LOCALE=en

# --- Optional (public-demo abuse protection; secret via `wrangler secret`) ---
# RATE_LIMIT_PER_MINUTE=10   # per-IP generate requests/min (0 or unset = disabled)
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Not needed (BYOK: no server-side key / database / login / payment) ---
# OPENAI_API_KEY      # ❌ entered by the end user in the UI
# MINIMAX_API_KEY     # ❌ entered by the end user in the UI (choose Global/China region)
# DATABASE_URL        # ❌
# AUTH_SECRET         # ❌
# STRIPE_SECRET_KEY   # ❌
