{
  // Production-only Wrangler config for the public deployment.
  //
  // This file is a TEMPLATE. Copy it to `wrangler.prod.jsonc` (gitignored) and
  // fill in your own private values. Keeping production-specific deployment
  // details (custom domain, account id) out of the open-source repo means
  // forks deploy to their own *.workers.dev domain by default and never
  // inherit this project's private infrastructure.
  //
  //   cp wrangler.prod.jsonc.example wrangler.prod.jsonc
  //   # edit wrangler.prod.jsonc, then:
  //   npm run deploy:prod
  //
  // `account_id` can also be provided via the CLOUDFLARE_ACCOUNT_ID env var
  // instead of being written here.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "simi-avatar",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  // "account_id": "<your-cloudflare-account-id>",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "NEXT_PUBLIC_APP_NAME": "Simi Avatar",
    "NEXT_PUBLIC_GITHUB_URL": "https://github.com/simi-studio/avatar",
    "NEXT_PUBLIC_DEFAULT_LOCALE": "en"
  },
  // Bind your own custom domain. The domain must already be on Cloudflare.
  "routes": [
    {
      "pattern": "avatar.example.com",
      "custom_domain": true
    }
  ]
}
